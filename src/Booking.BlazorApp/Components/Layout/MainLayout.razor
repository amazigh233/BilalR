@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main class="main-panel">
        <div class="top-row">
            <div class="topbar-meta">
                <span class="topbar-label">Zambiq Booking</span>
            </div>
            <AuthorizeView>
                <Authorized>
                    <div class="account-area">
                        <span class="user-chip">@GetInitials(context.User.Identity?.Name)</span>
                        <span class="account-name">@context.User.Identity?.Name</span>
                        <form method="post" action="/auth/logout">
                            <AntiforgeryToken />
                            <button class="btn btn-outline-secondary btn-sm" type="submit">Uitloggen</button>
                        </form>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a class="btn btn-outline-secondary btn-sm" href="/login">Inloggen</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "Z";
        }

        var parts = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .ToList();

        return parts.Count == 0
            ? "Z"
            : string.Concat(parts.Select(part => char.ToUpperInvariant(part[0])));
    }
}
