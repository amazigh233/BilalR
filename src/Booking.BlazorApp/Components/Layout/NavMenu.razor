<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Booking</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized Context="authState">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Dashboard
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/reservations">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Reserveringen
                    </NavLink>
                </div>

                <AuthorizeView Roles="Owner">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/restaurant">
                            <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Restaurant
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/opening-hours">
                            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Openingstijden
                        </NavLink>
                    </div>
                </AuthorizeView>

                @if (TryGetRestaurantId(authState.User, out var restaurantId))
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@($"booking/{restaurantId}")">
                            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Publieke pagina
                        </NavLink>
                    </div>
                }
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Inloggen
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private static bool TryGetRestaurantId(ClaimsPrincipal user, out Guid restaurantId)
    {
        var value = user.FindFirst(BookingAuthClaimTypes.RestaurantId)?.Value;
        return Guid.TryParse(value, out restaurantId);
    }
}
