@page "/admin/restaurant-accounts/create"
@attribute [Authorize(Roles = "SuperAdmin")]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject RestaurantAccountApiClient RestaurantAccountApi

<PageTitle>Restaurantaccount aanmaken</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Platformbeheer</p>
        <h1>Restaurantaccount aanmaken</h1>
        <p class="text-muted mb-0">Maak een nieuw restaurant met een eerste owner-account.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_successMessage))
{
    <div class="alert alert-success">@_successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}

<section class="content-section">
    <div class="section-heading">
        <h2>Nieuwe klant</h2>
    </div>

    <EditForm Model="_form" FormName="create-restaurant-account" OnValidSubmit="CreateAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-grid">
            <div class="form-field">
                <label for="restaurant-name">Restaurantnaam</label>
                <InputText id="restaurant-name" class="form-control" @bind-Value="_form.RestaurantName" />
            </div>

            <div class="form-field">
                <label for="phone-number">Telefoon</label>
                <InputText id="phone-number" class="form-control" @bind-Value="_form.PhoneNumber" />
            </div>

            <div class="form-field">
                <label for="owner-name">Naam eigenaar</label>
                <InputText id="owner-name" class="form-control" @bind-Value="_form.OwnerName" />
            </div>

            <div class="form-field">
                <label for="owner-email">E-mail eigenaar</label>
                <InputText id="owner-email" class="form-control" type="email" @bind-Value="_form.OwnerEmail" />
            </div>

            <div class="form-field">
                <label for="owner-password">Tijdelijk wachtwoord</label>
                <InputText id="owner-password" class="form-control" type="password" @bind-Value="_form.OwnerPassword" />
            </div>
        </div>

        <button class="btn btn-primary" type="submit" disabled="@_isSaving">
            @(_isSaving ? "Aanmaken..." : "Account aanmaken")
        </button>
    </EditForm>
</section>

@if (_createdAccount is not null)
{
    <section class="content-section mt-3">
        <div class="section-heading">
            <h2>Aangemaakt</h2>
            <a class="btn btn-outline-primary btn-sm" href="@($"/booking/{_createdAccount.RestaurantId}")">Publieke pagina</a>
        </div>
        <dl class="details-list">
            <div>
                <dt>Restaurant ID</dt>
                <dd>@_createdAccount.RestaurantId</dd>
            </div>
            <div>
                <dt>Owner user ID</dt>
                <dd>@_createdAccount.OwnerUserId</dd>
            </div>
            <div>
                <dt>Owner e-mail</dt>
                <dd>@_createdAccount.OwnerEmail</dd>
            </div>
        </dl>
    </section>
}

@code {
    private RestaurantAccountForm _form = new();
    private RestaurantAccountDto? _createdAccount;
    private bool _isSaving;
    private string? _errorMessage;
    private string? _successMessage;

    private async Task CreateAsync()
    {
        _isSaving = true;
        _errorMessage = null;
        _successMessage = null;
        _createdAccount = null;

        try
        {
            _createdAccount = await RestaurantAccountApi.CreateAsync(
                new CreateRestaurantAccountRequest(
                    _form.RestaurantName,
                    _form.OwnerName,
                    _form.OwnerEmail,
                    _form.OwnerPassword,
                    _form.PhoneNumber));

            _successMessage = "Restaurantaccount aangemaakt.";
            _form = new RestaurantAccountForm();
        }
        catch (ApiClientException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private sealed class RestaurantAccountForm
    {
        [Required(ErrorMessage = "Restaurantnaam is verplicht.")]
        public string RestaurantName { get; set; } = string.Empty;

        public string? PhoneNumber { get; set; }

        [Required(ErrorMessage = "Naam eigenaar is verplicht.")]
        public string OwnerName { get; set; } = string.Empty;

        [Required(ErrorMessage = "E-mail eigenaar is verplicht.")]
        [EmailAddress(ErrorMessage = "Gebruik een geldig e-mailadres.")]
        public string OwnerEmail { get; set; } = string.Empty;

        [Required(ErrorMessage = "Tijdelijk wachtwoord is verplicht.")]
        public string OwnerPassword { get; set; } = string.Empty;
    }
}
