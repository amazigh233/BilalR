@page "/admin"
@attribute [Authorize(Roles = "Owner,Staff")]
@rendermode InteractiveServer
@inject RestaurantApiClient RestaurantApi
@inject ReservationApiClient ReservationApi

<PageTitle>Admin dashboard</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Beheer</p>
        <h1>@(_restaurant?.Name ?? "Dashboard")</h1>
        <p class="text-muted mb-0">Reserveringen en instellingen voor je eigen restaurant.</p>
    </div>
    <a class="btn btn-primary" href="/admin/reservations">Reserveringen</a>
</section>

@if (_isLoading)
{
    <div class="loading-state">Dashboard laden...</div>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}
else if (_restaurant is not null)
{
    <div class="stats-grid">
        <div class="stat-card">
            <span class="stat-label">Restaurant</span>
            <strong>@_restaurant.Name</strong>
            <span class="text-muted small">Actieve beheeromgeving</span>
        </div>
        <a class="stat-card stat-link" href="/admin/reservations">
            <span class="stat-label">Reserveringen</span>
            <strong>@_reservations.Count</strong>
            <span class="text-muted small">@_reservations.Count(reservation => reservation.Status == ReservationStatus.New) nieuw</span>
        </a>
        <AuthorizeView Roles="Owner">
            <a class="stat-card stat-link" href="/admin/opening-hours">
                <span class="stat-label">Actie</span>
                <strong>Openingstijden</strong>
                <span class="text-muted small">Weekplanning beheren</span>
            </a>
            <a class="stat-card stat-link" href="/admin/staff">
                <span class="stat-label">Team</span>
                <strong>Medewerkers</strong>
                <span class="text-muted small">Toegang beheren</span>
            </a>
        </AuthorizeView>
    </div>

    <section class="content-section">
        <div class="section-heading">
            <h2>Laatste reserveringen</h2>
        </div>

        @if (_reservations.Count == 0)
        {
            <p class="empty-state"><strong>Nog geen reserveringen</strong>Nieuwe boekingen verschijnen hier zodra gasten reserveren.</p>
        }
        else
        {
            <div class="list-stack">
                @foreach (var reservation in _reservations
                    .OrderByDescending(reservation => reservation.ReservationDateTime)
                    .Take(5))
                {
                    <div class="list-row">
                        <div>
                            <strong>@reservation.CustomerName</strong>
                            <div class="text-muted small">@reservation.ReservationDateTime.ToString("dd-MM-yyyy HH:mm")</div>
                        </div>
                        <span class="status-pill @GetStatusBadgeClass(reservation.Status)">@reservation.Status</span>
                    </div>
                }
            </div>
        }
    </section>
}

@code {
    private RestaurantDto? _restaurant;
    private List<ReservationDto> _reservations = [];
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _restaurant = await RestaurantApi.GetCurrentAsync();
            _reservations = (await ReservationApi.GetCurrentRestaurantAsync()).ToList();
        }
        catch (ApiClientException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetStatusBadgeClass(ReservationStatus status)
    {
        return status switch
        {
            ReservationStatus.New => "status-new",
            ReservationStatus.Confirmed => "status-confirmed",
            ReservationStatus.Cancelled => "status-cancelled",
            ReservationStatus.NoShow => "status-noshow",
            _ => string.Empty
        };
    }
}
