{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dotnet build",
      "type": "shell",
      "command": "${workspaceFolder}/.dotnet-local/dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Booking.sln",
        "/nr:false",
        "-m:1"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet test",
      "type": "shell",
      "command": "${workspaceFolder}/.dotnet-local/dotnet",
      "args": [
        "test",
        "${workspaceFolder}/Booking.sln",
        "--no-build",
        "/nr:false",
        "-m:1"
      ],
      "group": "test",
      "problemMatcher": "$msCompile"
    }
  ]
}
